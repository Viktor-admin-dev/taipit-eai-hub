generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Division {
  id           Int           @id @default(autoincrement())
  name         String
  head         String?
  applications Application[]
  users        User[]
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  name         String
  position     String?
  divisionId   Int?
  division     Division?     @relation(fields: [divisionId], references: [id])
  role         String        @default("employee") // employee | leader | moderator | admin
  createdAt    DateTime      @default(now())
  applications Application[]
  forumTopics  ForumTopic[]
  forumReplies ForumReply[]
  votes        Vote[]
}

model Testimonial {
  id              Int      @id @default(autoincrement())
  name            String
  position        String
  roleDescription String?
  divisionName    String?
  photoUrl        String?
  summary         String?
  text            String
  tools           String?  // JSON array
  results         String?  // JSON array
  isPublished     Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model Application {
  id                  Int            @id @default(autoincrement())
  applicantName       String
  applicantEmail      String
  divisionId          Int
  division            Division       @relation(fields: [divisionId], references: [id])
  userId              Int?
  user                User?          @relation(fields: [userId], references: [id])
  title               String
  category            String         // efficiency | new_process | new_product | new_feature | analytics | content
  type                String         // idea | prototype | implementation
  format              String         // individual | team
  descriptionProblem  String
  descriptionSolution String
  expectedEffect      String
  resourcesNeeded     String?        // JSON array
  filesUrls           String?        // JSON array
  status              String         @default("submitted") // submitted | reviewing | finalist | winner | rejected
  scoreBusiness       Int?
  scoreInnovation     Int?
  scoreFeasibility    Int?
  scoreScalability    Int?
  scoreQuality        Int?
  expertComments      String?
  votesTotal          Int            @default(0)
  commissionScore     Int?
  finalScore          Float?
  placement           Int?           // 1, 2, 3 within division
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  teamMembers         TeamMember[]
  votes               Vote[]
  statusHistory       StatusChange[]
  aiEvaluations      AIEvaluation[]
  telegramLogs       TelegramLog[]
  newsPosts          NewsPost[]
}

model AIEvaluation {
  id               Int         @id @default(autoincrement())
  applicationId    Int
  application      Application @relation(fields: [applicationId], references: [id])

  // Scores
  scoreBusiness    Int
  scoreInnovation  Int
  scoreFeasibility Int
  scoreScalability Int
  scoreQuality     Int
  totalScore       Float

  // Verdict
  verdict          String      // "support" | "develop" | "rethink"
  oneLiner         String

  // For author
  authorStrengths     String  // JSON array
  developmentSteps    String  // JSON array
  resourcesForStart   String  // JSON array
  questionsToThink    String  // JSON array

  // For commission — author profile
  authorAiLevel    String      // "beginner" | "growing" | "advanced"
  authorQualities  String      // JSON array
  authorGrowthZone String

  // For commission — simplified idea
  problemSimple    String
  solutionSimple   String
  businessEffect   String

  // For commission — hidden potential
  hiddenPotential  String
  growthPath       String
  synergies        String      // JSON array

  // Recommendations
  mentorshipNeeded    String
  suggestedMentor     String
  resourcesToAllocate String   // JSON array

  // Legacy fields
  summary          String
  strengths        String      // JSON array
  weaknesses       String      // JSON array
  recommendations  String      // JSON array

  // Meta
  modelUsed           String   @default("claude-sonnet-4-20250514")
  promptTokens        Int?
  completionTokens    Int?

  createdAt           DateTime @default(now())

  @@index([applicationId])
}

model CommissionMember {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  role      String   // "ai_expert" | "business_expert" | "ceo"
  profile   String?  // "ai_advanced" | "business_focused"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model EmailLog {
  id            Int      @id @default(autoincrement())
  to            String
  subject       String
  recipientType String   // "author" | "commission"
  applicationId Int?
  status        String   // "sent" | "failed" | "pending"
  error         String?
  sentAt        DateTime @default(now())
}

model TelegramLog {
  id            Int         @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id])
  messageId     Int?
  chatId        String
  status        String      // "sent" | "failed"
  error         String?
  sentAt        DateTime    @default(now())

  @@index([applicationId])
}

model NewsPost {
  id            Int         @id @default(autoincrement())
  applicationId Int?
  application   Application? @relation(fields: [applicationId], references: [id])
  title         String
  body          String
  cta           String?
  isPublished   Boolean     @default(true)
  createdAt     DateTime    @default(now())

  @@index([createdAt])
}

model EmailCampaign {
  id             Int      @id @default(autoincrement())
  subject        String
  body           String
  recipientCount Int      @default(0)
  sentCount      Int      @default(0)
  status         String   @default("draft") // draft | sending | sent | failed
  triggerType    String   // "new_application" | "milestone" | "reminder"
  applicationIds String?  // JSON array
  createdAt      DateTime @default(now())
  sentAt         DateTime?
}

model Subscriber {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String?
  divisionId   Int?
  isActive     Boolean  @default(true)
  subscribedAt DateTime @default(now())

  @@index([isActive])
}

model StatusChange {
  id            Int         @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id])
  fromStatus    String
  toStatus      String
  comment       String?
  createdAt     DateTime    @default(now())
}

model TeamMember {
  id            Int         @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id])
  name          String
  position      String?
  divisionName  String?
}

model Vote {
  id            Int         @id @default(autoincrement())
  userId        Int
  user          User        @relation(fields: [userId], references: [id])
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id])
  points        Int         // 3 for employee, 10-15 for leader
  createdAt     DateTime    @default(now())

  @@unique([userId, applicationId])
}

model ForumTopic {
  id        Int          @id @default(autoincrement())
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  title     String
  body      String
  category  String?      // ai-tools | business | technical | contest
  status    String       @default("pending") // pending | published | rejected
  isPinned  Boolean      @default(false)
  createdAt DateTime     @default(now())
  replies   ForumReply[]
}

model ForumReply {
  id               Int        @id @default(autoincrement())
  topicId          Int
  topic            ForumTopic @relation(fields: [topicId], references: [id])
  userId           Int
  user             User       @relation(fields: [userId], references: [id])
  body             String
  status           String     @default("pending") // pending | published | rejected
  isModeratorReply Boolean    @default(false)
  createdAt        DateTime   @default(now())
}

model PageVisit {
  id          Int      @id @default(autoincrement())
  visitorHash String
  pagePath    String
  userAgent   String?
  ipHash      String?
  createdAt   DateTime @default(now())
}

model DailyStat {
  id             Int      @id @default(autoincrement())
  date           DateTime
  uniqueVisitors Int
  totalVisits    Int
  pagePath       String?

  @@unique([date, pagePath])
}

model SiteConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
